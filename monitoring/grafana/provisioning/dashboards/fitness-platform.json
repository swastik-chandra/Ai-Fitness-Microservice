{
  "dashboard": {
    "title": "Fitness Platform — Service Dashboard",
    "uid": "fitness-platform-main",
    "timezone": "browser",
    "refresh": "30s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [
      {
        "title": "Service Uptime",
        "type": "stat",
        "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "up{job=~\".*service.*|gateway|eureka\"}",
            "legendFormat": "{{job}}"
          }
        ]
      },
      {
        "title": "HTTP Request Rate (req/s)",
        "type": "timeseries",
        "gridPos": { "x": 6, "y": 0, "w": 10, "h": 8 },
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_count{status!~\"5..\"}[5m])",
            "legendFormat": "{{job}} - {{uri}}"
          }
        ]
      },
      {
        "title": "Error Rate (5xx)",
        "type": "timeseries",
        "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])",
            "legendFormat": "{{job}} - {{status}}"
          }
        ],
        "fieldConfig": {
          "defaults": { "color": { "mode": "fixed", "fixedColor": "red" } }
        }
      },
      {
        "title": "Response Time P95 (ms)",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket[5m])) * 1000",
            "legendFormat": "{{job}}"
          }
        ]
      },
      {
        "title": "JVM Heap Memory Usage",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "jvm_memory_used_bytes{area=\"heap\"} / 1024 / 1024",
            "legendFormat": "{{job}} (MB)"
          }
        ]
      },
      {
        "title": "Kafka Consumer Lag",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "kafka_consumer_records_lag_max",
            "legendFormat": "{{topic}} - {{group}}"
          }
        ]
      },
      {
        "title": "Active Database Connections",
        "type": "gauge",
        "gridPos": { "x": 12, "y": 16, "w": 6, "h": 8 },
        "targets": [
          {
            "expr": "hikaricp_connections_active",
            "legendFormat": "{{pool}}"
          }
        ]
      },
      {
        "title": "Redis Cache Hit Rate",
        "type": "stat",
        "gridPos": { "x": 18, "y": 16, "w": 6, "h": 8 },
        "targets": [
          {
            "expr": "rate(cache_gets_total{result=\"hit\"}[5m]) / (rate(cache_gets_total{result=\"hit\"}[5m]) + rate(cache_gets_total{result=\"miss\"}[5m])) * 100",
            "legendFormat": "{{cache}}"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "percent" }
        }
      }
    ]
  }
}
